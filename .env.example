# SAP-AI Copilot — ortam değişkenleri şablonu
# Bu dosyayı `.env` olarak kopyalayıp gerçek değerleri girin.
# `.env` ASLA commit'lenmez (.gitignore'da).

# ── AI servisleri ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.1-flash-lite

# ── MSSQL ───────────────────────────────────────────────────────────
DB_SERVER=10.0.0.1
DB_NAME=YourDatabase
DB_USER=your_user
DB_PASS=your_password

# ── Qdrant vektör DB ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=SAP-AI

# ── SAP bağlantısı (seed/fetch için) ────────────────────────────────
SAP_WSDL_URL=http://your-sap-host:8000/sap/bc/srt/wsdl/...
SAP_SERVICE_METHOD=ZWHSD_FG001_009_WS
SAP_USERNAME=your_sap_user
SAP_PASSWORD=your_sap_password

# ── SAS Servisi (data/configure_sas.py için — iç SAP hostname'i .env'de) ──
SAP_SAS_ENDPOINT=http://your-sap-host:8000/sap/bc/srt/rfc/sap/zai_rfc_fg001_002/100/zai_rfc_fg001_002/zai_rfc_fg001_002_ws
# SAP_SAS_WSDL_URL=http://your-sap-host:8000/sap/bc/srt/wsdl/flv_xxxx/bndg_url/...?sap-client=100

# ── Model override (opsiyonel) ──────────────────────────────────────
# SQL_MODEL=gpt-4o
# ANALYSIS_MODEL=gpt-4o

# ── E-posta / SMTP (rapor paylaşımı — opsiyonel) ────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=app_password
# SMTP_FROM=you@example.com
# SMTP_TLS=1

# ── Veri Yaşam Döngüsü (rollup / retention / sıkıştırma) ────────────
# Sıcak pencere: son N ay ham veri MSSQL'de tutulur (eskisi rollup'a iner)
HOT_WINDOW_MONTHS=6
# Gece rollup (özet tablo) üretimi açık (1) / kapalı (0)
ROLLUP_ENABLED=1
# Retention purge — ESKİ HAM SATIRLARI SİLER. Doğrulayana dek KAPALI (0) bırakın!
RETENTION_ENABLED=0
# Purge öncesi arşiv tablosuna kopyala (opsiyonel)
ARCHIVE_BEFORE_PURGE=0
