# SAP-AI Copilot — ortam değişkenleri şablonu
# Bu dosyayı `.env` olarak kopyalayıp gerçek değerleri girin.
# `.env` ASLA commit'lenmez (.gitignore'da).

# ── AI servisleri ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── MSSQL ───────────────────────────────────────────────────────────
DB_SERVER=10.0.0.1
DB_NAME=YourDatabase
DB_USER=your_user
DB_PASS=your_password

# ── Qdrant vektör DB ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=SAP-AI

# ── SAP bağlantısı (seed/fetch için) ────────────────────────────────
SAP_WSDL_URL=http://your-sap-host:8000/sap/bc/srt/wsdl/...
SAP_SERVICE_METHOD=ZWHSD_FG001_009_WS
SAP_USERNAME=your_sap_user
SAP_PASSWORD=your_sap_password

# ── Model override (opsiyonel) ──────────────────────────────────────
# SQL_MODEL=gpt-4o
# ANALYSIS_MODEL=gpt-4o

# ── E-posta / SMTP (rapor paylaşımı — opsiyonel) ────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=app_password
# SMTP_FROM=you@example.com
# SMTP_TLS=1
